# Copy to `.env` (same dir as compose.yml) and fill in. compose reads it
# automatically. Do not commit your real .env.

# Account the Supernote device logs in as.
NOTEHOOK_ACCOUNT=user@example.com

# MD5 hex of the account password. Generate with:
#   uv run scripts/hash_password.py
NOTEHOOK_PASSWORD_MD5=

# Public URL the device reaches this server at, through your TLS proxy.
# Must be externally reachable — it is embedded in upload/download URLs.
NOTEHOOK_BASE_URL=https://notehook.example.com

# Optional display name.
NOTEHOOK_USER_NAME=Supernote User
